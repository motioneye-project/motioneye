msgstr "aktiver dette, for å bruke og konfiugrere bevegelsesdeteksjon."

#: motioneye/templates/main.html:939
msgid "Movado-Detekto"
msgstr "Bevegelsesdeteksjon"

#: motioneye/templates/main.html:944
