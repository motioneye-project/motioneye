#: motioneye/templates/main.html:1283
msgid "Fiksas la labortagan tempintervalon por merkredoj."
msgstr "Establece el rango de tiempo operativo para los miércoles."

#: motioneye/templates/main.html:1286
msgid "Ĵaŭdo"
msgstr "Jueves"

#: motioneye/templates/main.html:1292
msgid "Fiksas la labortagan tempintervalon por ĵaŭdoj."
msgstr "Establece el rango de tiempo operativo para los jueves."

#: motioneye/templates/main.html:1295
msgid "Vendredo"
msgstr "Viernes"

#: motioneye/templates/main.html:1301
msgid "Fiksas la labortagan tempintervalon por vendredoj."
msgstr "Establece el rango de tiempo operativo para los viernes."

#: motioneye/templates/main.html:1304
msgid "Sabato"
msgstr "Sabado"

#: motioneye/templates/main.html:1310
msgid "Fiksas la labortagan tempintervalon por sabatoj."
msgstr "Establece el rango de tiempo operativo para los sábados."

#: motioneye/templates/main.html:1313
msgid "Dimanĉo"
msgstr "Domingo"

#: motioneye/templates/main.html:1319
msgid "Fiksas la labortagan tempintervalon por dimanĉoj."
msgstr "Establece el rango de tiempo operativo para los domingos."

