#: motioneye/static/js/main.js:791
msgid "\", ne nur tiuj kreitaj de motionEye!"
msgstr "\", மோசன் உருவாக்கியவை மட்டுமல்ல!"

#: motioneye/static/js/main.js:874
msgid "Ne eblas redakti la maskon sen valida kameraa bildo!"
